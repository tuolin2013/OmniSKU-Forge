# ================================================
# OmniSKU-Forge 环境变量模板
# 使用方法：cp .env.example backend/.env
#           然后填入真实密钥，严禁提交 .env 文件
# ================================================

# ---- AI 模型 API ----
# right.codes 代理密钥（必填）
RIGHT_CODE_API_KEY=your_right_code_api_key_here

# Codex / GPT 接入点
CODEX_BASE_URL=https://right.codes/codex/v1
CODEX_MODEL=gpt-5.5

# Gemini 接入点
GEMINI_BASE_URL=https://right.codes/gemini/v1
GEMINI_MODEL=gemini-3-pro-preview

# ---- 视频生成（Volcengine Ark Seedance）----
SEEDANCE_API_KEY=your_seedance_api_key_here
SEEDANCE_MODEL=doubao-seedance-2-0-260128

# ---- 视频生成服务（OmniSKU_Video，支持 RunPod / Modal / 自托管）----
# 部署后填入服务的公网地址，例如：
# LTX_VIDEO_BASE_URL=https://q9v8jl52w5pb58-8000.proxy.runpod.net
# LTX_VIDEO_BASE_URL=https://<workspace>--omni-ltx-video-video-api.modal.run
LTX_VIDEO_BASE_URL=

# ---- Tavily 联网搜索（可选，不填则降级为大模型推演）----
TAVILY_API_KEY=your_tavily_api_key_here

# ---- 对象存储（S3 兼容，多后端可配置）----
# STORAGE_PROVIDER：r2（默认/海外）| oss（阿里云，国内推荐）| cos（腾讯云）| s3
# 国内电商场景推荐用 OSS/COS，访问延迟远低于 R2。
# 各后端 endpoint / region 示例：
#   R2:  endpoint=https://<account>.r2.cloudflarestorage.com   region=auto
#   OSS: endpoint=https://oss-cn-hangzhou.aliyuncs.com          region=oss-cn-hangzhou
#   COS: endpoint=https://cos.ap-guangzhou.myqcloud.com         region=ap-guangzhou
STORAGE_PROVIDER=r2
STORAGE_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
STORAGE_PUBLIC_DOMAIN=https://your-public-domain.com
STORAGE_ACCESS_KEY_ID=your_access_key_id
STORAGE_SECRET_ACCESS_KEY=your_secret_access_key
STORAGE_BUCKET_NAME=ai-products
STORAGE_REGION=auto

# [兼容] 旧的 R2_* 变量仍可用（未设置 STORAGE_* 时自动回退读取）
# R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_DOMAIN=https://your-r2-public-domain.com
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET_NAME=ai-products


# ---- TTS 语音合成（Kokoro / OmniVoice-Studio）----
# 填入已部署的 Kokoro TTS 服务地址（支持 Modal 或自托管）
MODAL_TTS_URL=https://your-tts-service-url.example.com

# ---- TTS 语音合成（CosyVoice 2，支持情绪控制）----
MODAL_COSYVOICE_URL=https://your-cosyvoice-service-url.example.com

# ---- TTS 语音合成（EmotiVoice，支持情绪控制）----
MODAL_EMOTIVOICE_URL=https://your-emotivoice-service-url.example.com

# VoxCPM2 TTS（前端直连，需 NEXT_PUBLIC_ 前缀）
NEXT_PUBLIC_VOXCPM2_URL=https://your-voxcpm2-service-url.example.com

# ---- 前端（Next.js，可选）----
# 若前端与后端不在同一机器，修改此处
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
