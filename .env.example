# ================================================
# OmniSKU-Forge 环境变量模板
# 使用方法：cp .env.example backend/.env
#           然后填入真实密钥，严禁提交 .env 文件
# ================================================

# ---- AI 模型 API ----
# right.codes 代理密钥（必填）
RIGHT_CODE_API_KEY=your_right_code_api_key_here

# Codex / GPT 接入点
CODEX_BASE_URL=https://right.codes/codex/v1
CODEX_MODEL=gpt-5.5

# Gemini 接入点
GEMINI_BASE_URL=https://right.codes/gemini/v1
GEMINI_MODEL=gemini-3-pro-preview

# ---- 视频生成（Volcengine Ark Seedance）----
SEEDANCE_API_KEY=your_seedance_api_key_here
SEEDANCE_MODEL=doubao-seedance-2-0-260128

# ---- 视频生成（RunPod LTX-Video / Wan2.2）----
# RunPod 实例的公网代理地址，例如：
# LTX_VIDEO_BASE_URL=https://q9v8jl52w5pb58-8000.proxy.runpod.net
LTX_VIDEO_BASE_URL=

# ---- 视频生成（Modal Wan2.2 + LTX-Video）---- 优先级低于 RunPod
# 执行 `modal deploy backend/modal_video_service.py` 后填入
# 格式：https://<workspace>--omni-video-video-api.modal.run
MODAL_VIDEO_URL=https://your-workspace--omni-video-video-api.modal.run

# ---- Tavily 联网搜索（可选，不填则降级为大模型推演）----
TAVILY_API_KEY=your_tavily_api_key_here

# ---- Cloudflare R2 对象存储 ----
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=https://your-r2-public-domain.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=ai-products

# ---- TTS 语音合成（Modal 部署的 OmniVoice-Studio）----
# 执行 `modal deploy backend/modal_tts_service.py` 后，Modal 会输出服务 URL
# 格式：https://<workspace>--omnivoice-tts-api.modal.run
MODAL_TTS_URL=https://your-workspace--omnivoice-tts-api.modal.run

# CosyVoice 2 TTS（情绪控制，阿里出品）
# 执行 `modal deploy backend/modal_cosyvoice_service.py` 后填入
MODAL_COSYVOICE_URL=https://your-workspace--cosyvoice-tts-tts-api.modal.run

# EmotiVoice TTS（情绪控制，网易云音乐开源）
# 执行 `modal deploy backend/modal_emotivoice_service.py` 后填入
MODAL_EMOTIVOICE_URL=https://your-workspace--emotivoice-tts-tts-api.modal.run

# ---- 前端（Next.js，可选）----
# 若前端与后端不在同一机器，修改此处
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
